# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/

# Virtual environments
venv/
env/
.env/
.venv/

# IDE specific files
.idea/
.vscode/
*.swp
*.swo
*.code-workspace

# Jupyter Notebook
.ipynb_checkpoints

# Data files that shouldn't be version controlled
*.csv
*.json
*.txt
*.ics
bond-analytics/data/

# Docs generated by mkdocs/sphinx, do not track
docs/
mkdocs.yml

# Logs
*.log
log.txt

# macOS specific
.DS_Store

# Local configuration
.env
.env.local

# Ignore GIFs in the root
/*.gif

# Files not ready for release
staging/
bond-analytics/staging/

# Temporary files
tmp/
temp/
*.tmp
.trash/

# Temporary shell scripts
run*.sh
